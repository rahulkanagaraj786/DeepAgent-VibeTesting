# Anthropic (for spec inference, orchestrator, reasoning loop)
ANTHROPIC_API_KEY=your-anthropic-api-key

# TrueFoundry (replaces Blaxel)
TFY_API_KEY=your-truefoundry-api-key
TFY_WORKSPACE_FQN=your-workspace:your-workspace-name
TFY_HOST=https://app.truefoundry.com

# Aerospike (persistent memory — falls back to in-memory if not set)
AEROSPIKE_HOST=your-aerospike-host
AEROSPIKE_PORT=3000

# LLM fallbacks (used by pipeline/codegen.py)
FEATHERLESS_API_KEY=your-featherless-api-key
GEMINI_API_KEY=your-gemini-api-key
